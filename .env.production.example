# ===================================================================
# INTELLIGENCE ITA — Production Environment Variables
# ===================================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ===================================================================

# --- Database ---
POSTGRES_USER=intelligence
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key            # T2 Oracle (Claude Sonnet 4.6)
DEEPSEEK_API_KEY=your_deepseek_api_key              # T3 structured extraction (DeepSeek V3.2)
MISTRAL_API_KEY=your_mistral_api_key                # T4b SQL generation (Codestral 2)
INTELLIGENCE_API_KEY=CHANGE_ME_RUN_python_-c_"import secrets; print(secrets.token_urlsafe(32))"
ORACLE_ADMIN_KEY=CHANGE_ME_GENERATE_SEPARATE_ADMIN_KEY  # Bypasses Oracle 5/day rate limit
FRED_API_KEY=your_fred_api_key

# --- Frontend (build-time) ---
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# --- CORS ---
ALLOWED_ORIGINS=https://yourdomain.com

# --- Pipeline ---
LOG_LEVEL=INFO
PIPELINE_NOTIFY_ON_SUCCESS=true
PIPELINE_NOTIFY_ON_FAILURE=true
PIPELINE_MAX_LOG_DAYS=30

# --- Email Notifications (optional, for pipeline alerts) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=pipeline@yourdomain.com
# NOTIFY_EMAIL=your_email@gmail.com

# --- Backup ---
BACKUP_PASSWORD=CHANGE_ME_STRONG_ENCRYPTION_PASSWORD
