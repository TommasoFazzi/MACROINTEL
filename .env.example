# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/intelligence_ita

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here        # T2 Oracle (Claude Sonnet 4.6)
DEEPSEEK_API_KEY=your_deepseek_api_key_here          # T3 structured extraction (DeepSeek V3.2)
MISTRAL_API_KEY=your_mistral_api_key_here            # T4b SQL generation (Codestral 2)

# Optional: enable Anthropic prompt caching for Oracle system prompt (~70% input cost reduction)
# ANTHROPIC_PROMPT_CACHING=true

# ============================================================
# OpenBB API Keys (Financial Data)
# ============================================================
# FRED API Key (Free - Federal Reserve Economic Data)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Financial Modeling Prep (Optional - has free tier)
# Get yours at: https://financialmodelingprep.com/developer/docs/
# FMP_API_KEY=your_fmp_api_key_here

# Intrinio (Optional - premium data)
# INTRINIO_API_KEY=your_intrinio_api_key_here

# Polygon (Optional - real-time data)
# POLYGON_API_KEY=your_polygon_api_key_here
# ============================================================

# ============================================================
# Knowledge Base / External Data Sources
# ============================================================
# UCDP Conflict Events API (Free - registration required)
# Register at: https://ucdp.uu.se/apidocs/
# UCDP_API_TOKEN=your_ucdp_token_here

# Backup encryption password (used by deploy/backup-db.sh)
# BACKUP_PASSWORD=your_backup_password_here
# ============================================================

# API Security
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTELLIGENCE_API_KEY=your_api_key_here
# Admin key: bypasses Oracle 5/day rate limit (for personal use)
# ORACLE_ADMIN_KEY=your_admin_key_here

# Application Settings
LOG_LEVEL=INFO
REPORT_OUTPUT_DIR=./reports
DATA_DIR=./data

# Scheduling
DAILY_REPORT_TIME=08:00
TIMEZONE=Europe/Rome

# Daily Pipeline Configuration
PIPELINE_FAIL_FAST=true
PIPELINE_NOTIFY_ON_SUCCESS=true
PIPELINE_NOTIFY_ON_FAILURE=true
PIPELINE_MAX_LOG_DAYS=30
